const express = require("express");
const axios = require("axios");

const app = express();
app.use(express.json());

let token = null;

async function login() {
  const res = await axios.post("https://demo.tradovateapi.com/v1/auth/accesstokenrequest", {
    name: process.env.TV_USER,
    password: process.env.TV_PASS,
    appId: "KobiBot",
    appVersion: "1.0",
    cid: 1,
    sec: ""
  });

  token = res.data.accessToken;
  console.log("Connected to Tradovate");
}

async function placeOrder(action) {
  const side = action === "BUY" ? "Buy" : "Sell";

  const order = {
    accountSpec: process.env.ACCOUNT_ID,
    symbol: "MNQ",
    action: side,
    orderQty: 1,
    orderType: "Market",
    bracket1: {
      profitTarget: 80,
      stopLoss: 40
    }
  };

  await axios.post(
    "https://demo.tradovateapi.com/v1/order/placeorder",
    order,
    {
      headers: {
        Authorization: `Bearer ${token}`
      }
    }
  );

  console.log("Order sent:", action);
}

app.post("/", async (req, res) => {
  try {
    const action = req.body.action;

    if (!token) {
      await login();
    }

    if (action === "BUY" || action === "SELL") {
      await placeOrder(action);
    }

    res.send("OK");
  } catch (err) {
    console.error(err.response?.data || err.message);
    res.status(500).send("ERROR");
  }
});

app.listen(3000, () => {
  console.log("Bot running on port 3000");
});
